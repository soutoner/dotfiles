# Environment variables for chezmoi
# Copy this to .env and fill in your values
# Chezmoi will read these when applying templates

# Your full name (used in git config)
CHEZMOI_GIT_NAME="Your Name"

# Your email address (used in git config)
# IMPORTANT: Keep this in .env file, NOT in version control
CHEZMOI_GIT_EMAIL="your.email@example.com"

